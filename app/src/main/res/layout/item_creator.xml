<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp" app:cardCornerRadius="20dp" app:cardElevation="3dp">

    <!-- Everything lives inside a fixed-height FrameLayout so the gradient
         and info bar sit over the cover image. -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="220dp">

        <!-- Cover image (fills the whole card) -->
        <ImageView android:id="@+id/cover_image" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:background="?attr/colorSurfaceVariant" android:contentDescription="@null" />

        <!-- Gradient scrim so text is readable on any photo -->
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_creator_gradient" />

        <!-- Info bar pinned to the bottom of the card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:orientation="horizontal" android:paddingStart="14dp" android:paddingEnd="14dp" android:paddingBottom="14dp" android:paddingTop="8dp" android:gravity="center_vertical">

            <!-- Avatar circle -->
            <com.google.android.material.imageview.ShapeableImageView android:id="@+id/avatar_image" android:layout_width="46dp" android:layout_height="46dp" android:scaleType="centerCrop" android:background="?attr/colorSurfaceVariant" app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full" app:strokeWidth="2dp" app:strokeColor="#66FFFFFF" android:contentDescription="@null" />

            <!-- Name + subtitle -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">

                <TextView android:id="@+id/creator_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceTitleMedium" android:textColor="@android:color/white" android:shadowColor="#99000000" android:shadowRadius="4" android:shadowDx="0" android:shadowDy="1" android:ellipsize="end" android:maxLines="1" />

                <TextView android:id="@+id/creator_subtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceBodySmall" android:textColor="#CCFFFFFF" android:ellipsize="end" android:maxLines="1" />

            </LinearLayout>

            <!-- Post count pill -->
            <TextView android:id="@+id/post_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_count_pill" android:paddingHorizontal="10dp" android:paddingVertical="5dp" android:textAppearance="?attr/textAppearanceLabelSmall" android:textColor="@android:color/white" />

        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
